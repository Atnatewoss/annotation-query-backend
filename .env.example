# ==================== DATABASE CONNECTIONS ====================

# MongoDB (Required - for storing annotation history)
MONGO_URI=mongodb://localhost:27017/annotation_db
MONGODB_DOCKER_PORT=27017

# Neo4j Aura (Required - for graph database queries)
# Get these from: https://console.neo4j.io/
HUMAN_NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
HUMAN_NEO4J_USERNAME=neo4j
HUMAN_NEO4J_PASSWORD=your-password

FLY_NEO4J_URI=neo4j+s://your-fly-instance-id.databases.neo4j.io
FLY_NEO4J_USERNAME=neo4j
FLY_NEO4J_PASSWORD=your-password

# Elasticsearch (Optional - for search functionality)
# Get free account from: https://cloud.elastic.co/
ES_URL=https://your-cluster.es.us-east-1.aws.elastic-cloud.com:9243
ES_API_KEY=your-api-key

# ==================== APP CONFIGURATION ====================

APP_PORT=5000
DOCKER_HUB_REPO=annotation-backend

# Redis (Required - for rate limiting and caching)
REDIS_URL=redis://localhost:6379/0

# ==================== LLM CONFIGURATION (Optional) ====================

# Choose: openai, gemini, or leave empty to disable
LLM_MODEL=openai

# OpenAI API Key (if LLM_MODEL=openai)
OPENAI_API_KEY=sk-your-openai-api-key

# Gemini API Key (if LLM_MODEL=gemini)
GEMINI_API_KEY=your-gemini-api-key

# ==================== EMAIL CONFIGURATION (Optional) ====================

# For sending email notifications
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@yourdomain.com

# ==================== MONITORING (Optional) ====================

# Sentry for error tracking
SENTRY_DSN=your-sentry-dsn

# Axiom for logging
AXIOM_DATASET=your-dataset
AXIOM_TOKEN=your-token
